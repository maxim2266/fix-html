#!/bin/bash -e

{
  printf '%s\n' '<!DOCTYPE html>'
  printf '%s\n' '<html><head><meta charset="utf-8"><title>UTF-8 Test</title></head><body>'
  printf '\n'
  printf '%s\n' '<!-- Valid UTF-8 sequences -->'
  printf '%s\n' '<p>ASCII: Hello World</p>'
  printf '%s\n' $'<p>2-byte: \xc2\xa2 \xc2\xa9 \xc2\xae</p>'
  printf '%s\n' $'<p>3-byte: \xe2\x82\xac \xe2\x84\xa2 \xe2\x88\x9e</p>'
  printf '%s\n' $'<p>4-byte: \xf0\x9f\x98\x80 \xf0\x9f\x94\xa5</p>'
  printf '\n'
  printf '%s\n' '<!-- C1 control characters (U+0080-U+009F) -->'
  printf '%s\n' $'<p>C1 controls: \xc2\x80 \xc2\x81 \xc2\x90 \xc2\x9f</p>'
  printf '\n'
  printf '%s\n' '<!-- Non-characters (U+FDD0-U+FDEF) -->'
  printf '%s\n' $'<p>Non-chars: \xef\xb7\x90 \xef\xb7\xa0 \xef\xb7\xaf</p>'
  printf '\n'
  printf '%s\n' '<!-- Surrogates (U+D800-U+DFFF) -->'
  printf '%s\n' $'<p>Surrogates: \xed\xa0\x80 \xed\xaf\xbf \xed\xbf\xbf</p>'
  printf '\n'
  printf '%s\n' '<!-- Overlong sequences -->'
  printf '%s\n' $'<p>Overlong: \xc0\x80 \xc1\xbf \xe0\x80\x80</p>'
  printf '\n'
  printf '%s\n' '<!-- Invalid UTF-8 bytes -->'
  printf '%s\n' $'<p>Invalid bytes: \x80 \xfe \xff</p>'
  printf '\n'
  printf '%s\n' '<!-- Truncated sequence at EOF -->'
  printf '%s' $'<p>Truncated: \xe2\x82'
} > utf8.html
