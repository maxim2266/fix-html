#!/bin/bash

set -o pipefail

APP="./fix-html"
INPUT_DIR="tests/input"
EXPECTED_DIR="tests/expected"
FAILED=0
PASSED=0

for input in "$INPUT_DIR"/*.html
do
    name=$(basename "$input")
    expected="$EXPECTED_DIR/$name"

    if [ ! -f "$expected" ]
	then
        echo "SKIP: $name (no expected output)"
        continue
    fi

    if "$APP" -qq "$input" | diff -qZ - "$expected"
	then
        echo "PASS: $name"
        ((PASSED++))
    else
        echo "FAIL: $name"
        ((FAILED++))
    fi
done

echo "---"
echo "Passed: $PASSED, Failed: $FAILED"
exit $FAILED
