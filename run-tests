#!/bin/bash

set -eo pipefail

FAILED=0
PASSED=0

APP='../fix-html'

cd tests >/dev/null

for fname in 'bad.html' 'basic.html' 'utf8.html'
do
    expected="expected-$fname"

    if [ ! -f "$expected" ]
    then
        echo >&2 "SKIP: $fname (no expected output)"
        continue
    fi

    if "$APP" "$fname" | diff -uZ --color - "$expected"
    then
        echo >&2 "PASS: $fname"
        ((PASSED++)) || true
    else
        echo >&2 "FAIL: $fname"
        ((FAILED++)) || true
    fi
done

echo >&2 "---"
echo >&2 "Passed: $PASSED, Failed: $FAILED"
[ $FAILED -eq 0 ]
